# Top-most EditorConfig file
root = true

# Default
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ source and headers
[*.{cpp,cc,h,hpp}]
indent_style = tab
indent_size = 4
tab_width = 4

# JSON
[*.json]
indent_style = space
indent_size = 2

# XML project files
[*.{vcxproj,vcxproj.filters,sln}]
indent_style = space
indent_size = 2

# Batch files
[*.bat]
indent_style = tab
indent_size = 4
end_of_line = crlf

# PowerShell
[*.ps1]
indent_style = space
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2
